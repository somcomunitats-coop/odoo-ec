<odoo>
  <record
    id="view_pack_product_creator_wizard_form"
    model="ir.ui.view"
  >
    <field name="name">pack.product.creator.wizard.form</field>
    <field name="model">pack.product.creator.wizard</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field
              name="company_id"
              required="1"
              readonly="0"
              domain="[(1,'=',1)]"
              options="{'no_open': True}"
            />
            <field
              name="pack_categ_id"
              required="1"
              readonly="0"
              domain="[('parent_id','=', %(energy_communities.product_category_pack)d)]"
              options="{'no_open': True}"
            />
            <field name="name" required="1"/>
            <field name="description_sale" required="1" />
            <field name="lst_price" />
            <field name="taxes_id" widget="many2many_tags" />
            <field name="service_product_ids" widget="one2many">
              <tree>
                <field name="name" />
                <field name="description_sale" />
                <field name="lst_price" />
              </tree>
              <form>
                <group>
                  <field name="name" required="1" />
                  <field name="description_sale" required="1" />
                  <field name="lst_price" />
                </group>
              </form>
            </field>
          </group>
        </sheet>
        <footer>
          <button
            name="execute_create"
            string="Create Pack"
            type="object"
            class="btn-primary"
          />
          <button
            special="cancel"
            string="Cancelar"
            class="btn-secondary"
          />
        </footer>
      </form>
    </field>
  </record>
  <record
    model="ir.actions.act_window"
    id="pack_product_creator_wizard_action"
  >
      <field name="name">Pack product creator</field>
      <field name="res_model">pack.product.creator.wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
  </record>

</odoo>
