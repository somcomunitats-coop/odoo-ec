"        <p>\n"
"            Autokontsumo kolektiboaren proiektua\n"
"            <b>${ object.name }</b>\n"
"            energia komunitatearena\n"
"            <b>${ object.project_id.company_id.name }</b>\n"
"            fakturazio-prozesua hasi du <b>${ ctx['next_invoicing'] }</b>-n ezarritako errepikapenaren arabera.\n"
