<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="energy_selfconsumption.ProgressBarWidgetTemplate">
        <div class="o_progress_bar">
            <div class="progress-bar-container" t-att-style="component.containerStyle">
                <div class="progress-bar-green" t-att-style="component.progressStyle"></div>
                <div class="progress-bar-red" t-att-style="component.overlayStyle"></div>
            </div>
            <span><t t-esc="component.percentage.toFixed(2)"/>%</span>
            <span style="display: block;float: right;">
                <t t-esc="component.current_quantity.toFixed(2)"/> / 
                <t t-esc="component.max_quantity.toFixed(2)"/>
                <t t-esc="component.extra_label"/>
            </span>
        </div>
    </t>
</templates>