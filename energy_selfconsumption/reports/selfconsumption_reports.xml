<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="selfconsumption_manager_authorization_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <h2>Report</h2>
                            <p>This object's name is <span t-field="o.name"/></p>
                        </div>
                    </t>
                </t>
            </t>
        </template>


        <report id="selfconsumption_manager_authorization_report"
                string="Self-consumption Manager Report"
                name="energy_selfconsumption.selfconsumption_manager_authorization_template"
                model="energy_selfconsumption.selfconsumption"
                file="Manager Authorization"
                paperformat="base.paperformat_euro"
                report_type="qweb-pdf"
                print_report_name="(object.name)"
        />

    </data>
</odoo>
