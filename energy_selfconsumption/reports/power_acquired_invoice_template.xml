<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template inherit_id="account.report_invoice_document" id="power_acquired_invoice_template" primary="True">

            <xpath expr="//th[@name='th_quantity']" position="replace">
                <th name="th_power_acquired"><span>Power acquired</span></th>
            </xpath>

            <xpath expr="//th[@name='th_power_acquired']" position="after">
                <th name="th_invoiced_days"><span>Invoiced days</span></th>
            </xpath>
            
            <xpath expr="//th[@name='th_priceunit']" position="after">
                <th name="th_import"><span>Import</span></th>
            </xpath>

            <xpath expr="//th[@name='th_taxes']" position="replace"></xpath>
            <xpath expr="//th[@name='th_subtotal']" position="replace"></xpath>
            
            <xpath expr="//th[@name='th_invoiced_days']" position="after">
                <th name="th_quantity"><span>Quantity</span></th>
            </xpath>

            <xpath expr="//td[@name='account_invoice_line_name']" position="after">
                <td name="td_power_acquired">
                    <t t-foreach="line.selfconsumption_id.contract_ids" t-as="contract">
                        <t t-if="contract.next_period_date_start and contract.next_period_date_end">
                            <t t-esc="(((contract.next_period_date_end - contract.next_period_date_start).days) + 1)* line.selfconsumption_id.power"/><span> kW/day</span>
                        </t>
                        <t t-else="contract.next_period_date_start or contract.next_period_date_end">
                            0 kW/day
                        </t>
                    </t>
                </td>
            </xpath>

            <xpath expr="//td[@name='td_power_acquired']" position="after">
                <td name="td_invoiced_days">    
                     <t t-foreach="line.selfconsumption_id.contract_ids" t-as="contract">
                        <t t-if="contract.next_period_date_start and contract.next_period_date_end">
                            <t t-esc="((contract.next_period_date_end - contract.next_period_date_start).days) + 1"/>
                        </t>
                        <t t-else="contract.next_period_date_start or contract.next_period_date_end">
                            0
                        </t>
                    </t>
                </td>
            </xpath>

            <xpath expr="//span[@id='line_tax_ids']" position="replace"></xpath> 
        </template>

        <template id="report_invoice_with_payments" inherit_id="account.report_invoice_with_payments">
            <xpath expr='//t[@t-call="account.report_invoice_document"]' position="after">
                <t t-if="o._get_name_invoice_report() == 'energy_selfconsumption.power_acquired_invoice_template'"
                    t-call="energy_selfconsumption.power_acquired_invoice_template" t-lang="lang"/>
            </xpath>
        </template>
    </data>
</odoo>