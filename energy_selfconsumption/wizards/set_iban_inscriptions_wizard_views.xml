<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View set_iban_inscriptions form -->
    <record id="view_set_iban_inscriptions_form" model="ir.ui.view">
        <field name="name">view.set_iban_inscriptions.form</field>
        <field name="model">set_iban_inscriptions</field>
        <field name="arch" type="xml">
            <form string="Set_iban_inscriptions">
                <div class="oe_title">
                    <label for="name"/>
                    <h1>
                        <field name="name" placeholder="Name..."/>
                    </h1>
                </div>
                <footer>
                    <button name="add" type="object" string="Add" class="oe_highlight"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action set_iban_inscriptions -->
    <record id="action_set_iban_inscriptions" model="ir.actions.act_window">
        <field name="name">Set_iban_inscriptions</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">set_iban_inscriptions</field>
        <field name="view_mode">form</field>
        <field name="binding_model_id" ref="addon.model_model_name"/>
        <field name="target">new</field>
    </record>

</odoo>
