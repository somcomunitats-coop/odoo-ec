<?xml version="1.0" encoding="utf-8" ?>
<!--
Clean Supply Point Assignation Wizard Views
============================================

This file contains views for the supply point assignation cleaning wizard
that allows removing supply point assignations from distribution tables.

Main functionalities:
- Confirmation dialog for cleaning assignations
- Warning message display
- Confirm/Cancel actions
- Safe removal of supply point assignations
- Integration with distribution table management
-->
<odoo>

    <!-- Form View: Clean Supply Point Assignation Wizard -->
    <record id="view_clean_supply_point_assignation_wizard" model="ir.ui.view">
        <field name="name">clean.supply.point.assignation.wizard.form</field>
        <field name="model">clean.supply.point.assignation.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm">
                <!-- Warning Message -->
                <group>
                    <field name="message" nolabel="1" />
                </group>
                
                <!-- Footer with Confirmation Actions -->
                <footer>
                    <button string="Confirm"
                            type="object"
                            name="action_confirm"
                            class="btn-primary" />
                    <button string="Cancel"
                            type="object"
                            name="action_cancel"
                            class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>

    <!-- Action Window: Clean Supply Point Assignation Wizard -->
    <record id="action_confirm_wizard" model="ir.actions.act_window">
        <field name="name">Clean supply point assignation Wizard</field>
        <field name="res_model">clean.supply.point.assignation.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'active_ids': active_ids}</field>
    </record>
    
</odoo>
