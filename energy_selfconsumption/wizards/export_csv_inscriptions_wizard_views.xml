<odoo>
    <record id="view_export_csv_inscritions_wizard" model="ir.ui.view">
        <field name="name">export.csv.inscritions.wizard.form</field>
        <field name="model">export.csv.inscritions.wizard</field>
        <field name="arch" type="xml">
            <form string="Exportar CSV">
                <group>
                    <field name="file_data" filename="file_name" />
                    <field name="file_name" />
                </group>
                <footer>
                    <button string="Exportar CSV" type="object" name="exportar_csv" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_export_csv_inscritions_wizard" model="ir.actions.act_window">
        <field name="name">Exportar CSV</field>
        <field name="res_model">export.csv.inscritions.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
