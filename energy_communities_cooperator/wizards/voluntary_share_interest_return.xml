<odoo>
    <data>
        <record id="view_voluntary_share_interest_return_form" model="ir.ui.view">
            <field name="name">voluntary.share.interest.return.wizard.form</field>
            <field name="model">voluntary.share.interest.return.wizard</field>
            <field name="arch" type="xml">
                <form string="Return voluntary shares interest">
                    <sheet>
                        <group>
                            <field name="interest" required="1" />
                        </group>
                    </sheet>
                    <footer>
                        <button
              name="execute_return"
              string="Execute"
              type="object"
              class="btn-primary"
            />
                        <button
              string="Cancelar"
              class="btn-secondary"
              special="cancel"
            />
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
