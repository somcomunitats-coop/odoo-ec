<odoo>
    <data>
        <record id="email_template_confirmation_voluntary_share" model="mail.template">
            <field name="name">Confirmation Email for CE Voluntary Share Receipt</field>
            <field
        name="email_from"
      >{{(object.company_id.coop_email_contact or object.company_id.email_formatted)}}</field>
            <field
        name="subject"
      >Contribute to {{object.company_id.name}} Ref. ACSV{{object.id}}</field>
            <field name="email_to">{{object.email}}</field>
            <field
        name="email_cc">{{((object.company_id.parent_id and object.company_id.parent_id.hierarchy_level == 'coordinator' and object.company_id.parent_id.notify_to_coord_child_ccee_submissions and (object.company_id.parent_id.coop_email_contact or object.company_id.parent_id.email_formatted)) or '')}}</field>
            <field
        name="reply_to"
      >{{(object.company_id.coop_email_contact or object.company_id.email_formatted)}}</field>
            <field name="model_id" ref="model_subscription_request" />
            <field name="auto_delete" eval="False" />
            <field
        name="lang"
      >{{(object.lang or object.company_id.default_lang_id.code or object.company_id.partner_id.lang)}}</field>
            <field name="is_cooperator_template" eval="True" />
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
    Dear <t t-out="object.firstname"/>,<br/><br/>
    We confirm that we have correctly received your request to make a voluntary contribution to the capital social of <b><t t-out="object.company_id.name"/></b>, with the following data:<br/><br/>
    <ul>
        <li>Partner VAT: <b><t t-out="object.vat"/></b></li>
        <li>Partner name: <b><t t-out="object.firstname"/> <t t-out="object.lastname"/></b></li>
        <li>Charging account: <b><t t-out="object.iban"/></b></li>
        <li>Subscription amount: <b><t t-out="object.subscription_amount"/> €</b></li>
    </ul>
    <br/>
    In the next few days you will receive the bank charge in this account, please verify that all the data
    provided is correct and you have the money you want to invest, to avoid any incident in the
    draft of the receipt.
    <br/><br/>
    Once the validity of the payment has been verified, you will receive a new notification confirming the
    contribution made and detailing the particular conditions of your contribution.
    <br/><br/>
    Thank you for your involvement with the cooperative and inform you that for any doubt or clarification you can
    <t t-if="object.company_id.website">
     consult our website: <a t-if="object.company_id.website" t-att-href="object.company_id.website"><t t-out="object.company_id.website"/></a>
    or
    </t> send us an email to <t t-out="object.company_id.email"/>.
    <br/><br/>
    Get the word out by explaining the project to family and friends. The more we are, the further we will go!
    <br/>
    Thank you very much and good energy!
    <br/><br/>
    We keep in touch for any questions.<br/>
    <a href="https://somcomunitats.coop/recursos/">Resources and FAQs</a><br/><br/>
    Yours faithfully,<br/><br/>
    <u><t t-out="object.company_id.name"/></u><br/>
    <t t-if="object.company_id.street">
        <t t-out="object.company_id.street"/><br/>
    </t>
    <t t-if="object.company_id.street2">
        <t t-out="object.company_id.street2"/><br/>
    </t>
    <t t-if="object.company_id.city or object.company_id.zip">
        <t t-out="('%s %s'%((object.company_id.zip or ''),(object.company_id.city or '')))"/><br/>
    </t>
    <t t-if="object.company_id.country_id">
        <t t-out="('%s %s'%((object.company_id.state_id and ('%s, ' % object.company_id.state_id.name) or ''),(object.company_id.country_id.name or '')))"/><br/>
    </t>
    <t t-if="object.company_id.phone">
        Phone: <t t-out="object.company_id.phone"/><br/>
    </t>
    <t t-if="object.company_id.website">
        Web: <a t-if="object.company_id.website" t-att-href="object.company_id.website"><t t-out="object.company_id.website"/></a><br/>
    </t>
    <div>
        <img t-if="object.company_id.logo_url" t-att-src="('/web/image/res.company/%s/logo' % object.company_id.id)" style="width: 150px;"/>
    </div>
</p>
</div>
</field>
        </record>

    <record
      id="email_template_voluntary_share_interest_return"
      model="mail.template"
    >
            <field name="name">Voluntary shares interest return email</field>
            <field name="email_from">${object.company_id.email}</field>
            <field
        name="subject"
      >[${object.company_id.comercial_name}] Voluntary share interest return</field>
            <field name="email_to">${object.partner_id.name}</field>
            <field name="model_id" ref="model_account_move" />
            <field name="auto_delete" eval="False" />
            <field name="lang">${object.partner_id.lang}</field>
            <field name="body_html">
                <![CDATA[
                    <div style="font-family: 'Lucica Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; ">
                        <p>Hello ${object.partner_id.firstname},</p><br/>
                        <p>We have generated the yearly interest return of your voluntary shares contribution.</p>
                        % if object.partner_bank_id:
                        <p>Soon you'll receive a transfer on your IBAN account finished on: ${object.partner_bank_id.acc_number[-4:]}.
                        % else:
                          <p>Soon you'll receive a transfer on your IBAN account.
                        % endif
                        <p>The summary of the transaction:</p>
                        <p></p>
                        <p><ul>
                          <li><strong>Period:</strong> from ${object.voluntary_share_interest_return_id.start_date_period.strftime('%d/%m/%Y')} to ${object.voluntary_share_interest_return_id.end_date_period.strftime('%d/%m/%Y')}</li>
        <li><strong>Total contribution:</strong> ${str("%.2f" | format(object.voluntary_share_total_contribution)).replace('.',',')}€</li>
                          <li><strong>Total interest:</strong> ${str("%.2f" | format(object.amount_untaxed)).replace('.',',')}€</li>
                          <li><strong>Taxes:</strong> ${str("%.2f" | format(object.amount_tax)).replace('.',',')}€</li>
                          <li><strong>Total to receive:</strong> ${str("%.2f" | format(object.amount_total)).replace('.',',')}€</li>
                        </ul></p>
                        <p>Don't hesitate to contact us at <a href="${object.company_id.email}">${object.company_id.email}</a> for any question you might have using the code: ${object.name}</p>
                        <p>Thanks for your contribution helping generate our green energy.<p>
                        <p>Best regards,</p>
                        <p></p>
                        <p>${object.company_id.comercial_name}</p>
                    </div>
                ]]>
            </field>
            <field
        name="report_template"
        ref="action_voluntary_share_interest_return_invoices"
      />
            <field
        name="report_name"
      >${(object.name or "voluntary_share_interest_return").replace("/", "_")}${object.state == "draft" and "_draft" or ""}</field>
        </record>
    </data>
</odoo>
