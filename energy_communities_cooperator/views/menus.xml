<odoo>
  <record model="ir.ui.menu" id="cooperator.menu_cooperator_templates">
    <field
      name="groups_id"
      eval="[(6,0,[ref('energy_communities.group_platform_manager')])]"
    />
  </record>
  <record
      id="view_ec_formulas_window"
      model="ir.actions.act_window"
  >
    <field name="name">Formulas (quantity)</field>
    <field name="res_model">contract.line.qty.formula</field>
    <field name="view_mode">tree,form</field>
  </record>
  <menuitem
      id="ec_formulas_menu"
      name="Formulas"
      action="view_ec_formulas_window"
      groups="energy_communities.group_platform_manager"
      parent="energy_communities.ce_config_menu"
      sequence="500"

  />
  <record id="action_partner_cooperator_form_invited" model="ir.actions.act_window">
      <field name="name">Contacts</field>
      <field name="res_model">res.partner</field>
      <field name="view_mode">kanban,tree,form</field>
      <field name="context">
          {
              "create": False,
              "search_default_invited": True,
          }
      </field>
      <field name="help" type="html">
          <p class="o_view_nocontent_neutral_face">No contacts found</p>
      </field>
  </record>
  <menuitem
    name="Invited to participate"
    id="menu_cooperator_cooperator_invited"
    action="action_partner_cooperator_form_invited"
    parent="cooperator.menu_cooperator_main_coop"
    sequence="15"
  />
</odoo>
