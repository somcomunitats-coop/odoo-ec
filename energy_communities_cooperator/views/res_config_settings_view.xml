<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_energy_communities_cooperator_view_form" model="ir.ui.view">
        <field name="name">Energy Communities Cooperators</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="cooperator.res_config_settings_cooperator_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@id='email_settings']" position="after">
                <h2>Voluntary shares</h2>
                <div class="row mt16 o_settings_container" id="mandatory_contribution_base_form_settings">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="voluntary_share_url_individual" string="URL to the voluntary share form for individuals" />
                            <span class="fa fa-lg fa-building-o" title="Values set here are company-specific." aria-label="Values set here are company-specific." groups="base.group_multi_company" role="img"/>
                            <div class="text-muted">
                                URL to the voluntary share form for individuals
                            </div>
                            <field name="voluntary_share_url_individual" />
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="voluntary_share_form_header_text" string="Voluntary Share Form Header Text" />
                            <span class="fa fa-lg fa-building-o" title="Values set here are company-specific." aria-label="Values set here are company-specific." groups="base.group_multi_company" role="img"/>
                            <div class="text-muted">
                                Display the voluntary share form header text on the cooperator website form
                            </div>
                            <field name="voluntary_share_form_header_text" />
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="voluntary_share_id" string="Voluntary share to show on website" />
                            <span class="fa fa-lg fa-building-o" title="Values set here are company-specific." aria-label="Values set here are company-specific." groups="base.group_multi_company" role="img"/>
                            <div class="text-muted">
                                Select the voluntary share to show on the cooperator website form
                            </div>
                            <field name="voluntary_share_id" />
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="voluntary_share_journal_account" string="Voluntary shares journal" />
                            <span class="fa fa-lg fa-building-o" title="Values set here are company-specific." aria-label="Values set here are company-specific." groups="base.group_multi_company" role="img"/>
                            <div class="text-muted">
                                Select the journal to use for the voluntary shares
                            </div>
                            <field name="voluntary_share_journal_account" />
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="voluntary_share_email_template" string="Voluntary share return email template" />
                            <span class="fa fa-lg fa-building-o" title="Values set here are company-specific." aria-label="Values set here are company-specific." groups="base.group_multi_company" role="img"/>
                            <div class="text-muted">
                                Select the email template to use for the voluntary shares return email
                            </div>
                            <field name="voluntary_share_email_template" />
                        </div>
                    </div>
                </div>
                <h2>Cooperator shares</h2>
                <div class="row mt16 o_settings_container" id="mandatory_contribution_base_form_settings">
                    <div class="col-12 o_setting_box">
                        <div class="o_setting_left_pane">
                            
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="cooperator_share_form_header_text" string="Customizable paragraph in the header text of the form" />
                            <span class="fa fa-lg fa-building-o" title="Values set here are company-specific." aria-label="Values set here are company-specific." groups="base.group_multi_company" role="img"/>
                            <div class="text-muted">
                                Display the customizable paragraph in the header text of the form on the cooperator website form
                            </div>
                            <field name="cooperator_share_form_header_text" />
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="product_website" />
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="product_website" string="Product selector in BASE form" />
                            <span class="fa fa-lg fa-building-o" title="Values set here are company-specific." aria-label="Values set here are company-specific." groups="base.group_multi_company" role="img"/>
                            <div class="text-muted">
                                Display the product selector in the BASE form on the cooperator website form
                            </div>
                        </div>
                    </div>
                </div>
                <h2>Invitation shares</h2>
                <div class="row mt16 o_settings_container" id="mandatory_contribution_base_form_settings">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="invitation_share_url_individual" string="URL to the invitation share form for individuals" />
                            <span class="fa fa-lg fa-building-o" title="Values set here are company-specific." aria-label="Values set here are company-specific." groups="base.group_multi_company" role="img"/>
                            <div class="text-muted">
                                URL to the invitation share form for individuals
                            </div>
                            <field name="invitation_share_url_individual" />
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="invitation_share_url_company" string="URL to the invitation share form for companies" />
                            <span class="fa fa-lg fa-building-o" title="Values set here are company-specific." aria-label="Values set here are company-specific." groups="base.group_multi_company" role="img"/>
                            <div class="text-muted">
                                URL to the invitation share form for companies
                            </div>
                            <field name="invitation_share_url_company" />
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
