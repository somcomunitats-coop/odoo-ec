<odoo>
  <record id="view_category_property_form" model="ir.ui.view">
    <field name="name">product.category.property.form.inherit (cooperator)</field>
    <field name="model">product.category</field>
    <field name="inherit_id" ref="product.product_category_form_view"/>
    <field name="arch" type="xml">
      <group name="first" position="after">
        <group string="URLs">
          <field name="type_url" attrs="{'invisible': [('type_url', '=', False)]}" />
          <button name="url_individual_button" type="object" class="btn btn-primary" string="URL individual" attrs="{'invisible': [('type_url', '=', False)]}" />
          <button name="url_company_button" type="object" class="btn btn-primary" string="URL company" attrs="{'invisible': [('type_url', '=', False)]}" />
        </group>
        <group string="Product Website">
          <field name="product_website" />
          <field name="product_qty_must_be_read_only" />
        </group>
      </group>
    </field>
  </record>
</odoo>
