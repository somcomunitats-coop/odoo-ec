<odoo>
  <record id="cooperator_view_partner_form" model="ir.ui.view">
    <field name="name">view_company_form.inherit</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="cooperator.view_partner_form" />
    <field name="arch" type="xml">
      <field name="member" position="after">
        <field name="cooperator" />
        <field name="old_member" />
      </field>
      <group name="approvals" position="after">
        <group>
          <field name="cooperative_membership_id" />
          <field name="cooperative_membership_ids" />
          <field name="subscription_request_ids" />
          <field name="share_ids" />
        </group>
      </group>
    </field>
  </record>
</odoo>
