#: code:addons/energy_communities_cooperator/config.py:0
#, python-format
msgid ""
"<p id='transfer_text'>To become a member, you must first fill out this "
"questionnaire and then make the initial financial contribution of <span "
"id='prodPrice'>%(product_price)s</span>%(currency_symbol)s by following the "
"steps we will send you by email once we have received your request.</p>"
msgstr ""
"<p id='transfer_text'>Bazkidea izateko, lehenik eta behin, formulario hau "
"bete behar duzu. Bertan, banku-kontu bat eta banku-ordainagiri bat "
"bidaltzeko baimena eskatzen dizugu, hasierako <span "
"id='prodPrice'>%(product_price)s</span> %(currency_symbol)s sartu vejar dira"
" posta elektronikoz bidaliko zalzuen kontu korronte zenbaklan.</p>"

#. module: energy_communities_cooperator
#. odoo-python
#: code:addons/energy_communities_cooperator/config.py:0
#: code:addons/energy_communities_cooperator/config.py:0
#, python-format
msgid ""
"<p id='transfer_text'>To formalize the contribution, you must fulfill this "
"form and lateron proceed to pay the initial share of <span "
"id='prodPrice'>%(product_price)s</span>%(currency_symbol)s by follow the "
"steps you will receive by email.</p>"
msgstr ""
"<p id='transfer_text'>Ekarpena formalizatzeko, formulario hau bete behar "
"duzu eta gero <span id='prodPrice'>%(product_price)s</span> "
"%(currency_symbol)s-ren hasierako zatia ordaindu behar duzu posta "
"elektronikoz jasoko dituzun urratsak jarraituz.</p>"

#. module: energy_communities_cooperator
#. odoo-python
#: code:addons/energy_communities_cooperator/config.py:0
#: code:addons/energy_communities_cooperator/config.py:0
#, python-format
msgid ""
"<p>Once you become a member, you will be able to use the services available "
"to the energy community and, at the same time, be part of a movement for "
"social transformation and a new energy model</p>"
msgstr ""
"<p>Bazkide zarenean, komunitate energetikoaren zerbitzuak erabili ahal "
"izango dituzu, eta gizartea eta energia-eredua aldatzeko mugimenduaren parte"
" izango zara.</p>"

#. module: energy_communities_cooperator
#. odoo-python
#: code:addons/energy_communities_cooperator/config.py:0
#: code:addons/energy_communities_cooperator/config.py:0
#, python-format
msgid ""
"<p>Once your request has been received, you will receive a confirmation "
"email with instructions to follow.</p><p>Note: If you are not yet a member, "
"please complete the following forms: <a "
"href='/subscription/member/%(external_id)s'>INDIVIDUAL MEMBERSHIP "
"REGISTRATION</a> and <a "
"href='/subscription/company_member/%(external_id)s'>LEGAL ENTITY MEMBERSHIP "
"REGISTRATION</a></p>"
msgstr ""
"<p>Zure eskaera jasotzen dugunean, berrespen-mezu bat jasoko duzu, jarraitu "
"beharreko jarraibideekin.</p><p> Oharra: Mesedez, oraindik bazkide ez "
"bazara, formulario hauek erabili behar dituzu:<a "
"href='/subscription/member/%(external_id)s'>BANAKAKO KONTAKTUA</a> eta <a "
"href='/subscription/company_member/%(external_id)s'>PERTSONA JURIDIKOA DEN "
"KONTAKTUA</a>.</p>"

