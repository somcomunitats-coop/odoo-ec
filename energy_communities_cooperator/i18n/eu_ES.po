#, python-format
msgid ""
"<p id='sepa_text'>To join, you must first fill out this form where we ask "
"for a bank account and authorization to issue a bank receipt to collect the "
"initial mandatory financial contribution of <span "
"id='prodPrice'>%(product_price)s</span>%(currency_symbol)s</p>"
msgstr ""
"<p id='sepa_text'>Bazkide izateko, lehenbizi formulario hau bete behar duzu;"
" bertan, bankuko ordainagiri bat igortzeko baimena eskatzen dizugu, honen "
"nahitaezko hasierako ekarpena kobratzeko: <span "
"id='prodPrice'>%(product_price)s</span> %(currency_symbol)s-ko hasierako "
"nahitaezko diru ekarpena kobratzeko.</p>"

