#, python-format
msgid ""
"<p id='sepa_text'>To become a member, you must first fill out this form, "
"where we ask you for your bank account details and authorization to issue a "
"direct debit to collect the initial contribution of <span "
"id='prodPrice'>%(product_price)s</span>%(currency_symbol)s</p>"
msgstr ""
"<p id='sepa_text'>Bazkidea izateko, lehenik eta behin, formulario hau bete "
"behar duzu. Bertan, banku-kontu bat eta banku-ordainagiri bat bidaltzeko "
"baimena eskatzen dizugu, hasierako ( <span "
"id='prodPrice'>%(product_price)s</span> %(currency_symbol)s) kobratzeko.</p>"

#. module: energy_communities_cooperator
#. odoo-python
#: code:addons/energy_communities_cooperator/config.py:0
#: code:addons/energy_communities_cooperator/config.py:0
#, python-format
msgid ""
"<p id='sepa_text'>To formalize the contribution, you must first fill out "
"this form where we ask for a bank account and authorization to issue a bank "
"receipt to collect the initial mandatory financial contribution of <span "
"id='prodPrice'>%(product_price)s</span>%(currency_symbol)s</p>"
msgstr ""
"<p id='sepa_text'>Ekarpena formalizatzeko, lehenik formulario hau bete behar"
" duzu, non banku-kontu bat eta hasierako derrigorrezko ekarpen ekonomikoa ( "
"<span id='prodPrice'>%(product_price)s</span> %(currency_symbol)s) jasotzeko"
" banku-agiria emateko baimena eskatzen dizugun.</p>"

#. module: energy_communities_cooperator
#. odoo-python
#: code:addons/energy_communities_cooperator/config.py:0
