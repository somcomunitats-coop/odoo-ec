#. module: energy_communities_cooperator
#: model:mail.template,body_html:energy_communities_cooperator.email_template_confirmation_voluntary_share
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px; font-size: 13px;"
"\">\n"
"                        Dear <t t-out=\"object.firstname\"></t>,<br><br>\n"
"                        We confirm that we have correctly received your "
"request to make a voluntary contribution to the capital social of <b><t t-"
"out=\"object.company_id.name\"></t></b>, with the following data:<br><br>\n"
"                        <ul>\n"
"                            <li>Partner VAT: <b><t t-out=\"object.vat\"></"
"t></b></li>\n"
"                            <li>Partner name: <b><t t-"
"out=\"object.firstname\"></t> <t t-out=\"object.lastname\"></t></b></li>\n"
"                            <li>Charging account finished on: <b><t t-"
"out=\"object.iban[-4:]\"></t></b></li>\n"
"                            <li>Subscription amount: <b><t t-"
"out=\"object.subscription_amount\"></t> €</b></li>\n"
"                        </ul>\n"
"                        <br>\n"
"                        In the next few days you will receive the bank "
"charge in this account, please verify that all the data\n"
"                        provided is correct and you have the money you want "
"to invest, to avoid any incident in the\n"
"                        draft of the receipt.\n"
"                        <br><br>\n"
"                        Once the validity of the payment has been verified, "
"you will receive a new notification confirming the contribution made.\n"
"                        <br><br>\n"
"                        Thank you for your involvement and we inform you "
"that for any doubt or clarification you can\n"
"                        <t t-if=\"object.company_id.website\">\n"
"                        consult our website: <a t-"
"if=\"object.company_id.website\" t-att-"
"href=\"object.company_id.website\"><t t-out=\"object.company_id.website\"></"
"t></a>\n"
"                        or\n"
"                        </t> send us an email to <t t-"
"out=\"object.company_id.email\"></t>.\n"
"                        <br><br>\n"
"                        Get the word out by explaining the project to "
"family and friends. The more we are, the further we will go!\n"
"                        <br>\n"
"                        Thank you very much and good energy!\n"
"                        <br><br>\n"
"                        We keep in touch for any questions.<br>\n"
"                        Yours faithfully,<br>\n"
"                    </p>\n"
"                </div>\n"
"            "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\"><p style=\"margin: 0px; padding: "
"0px; font-size: 13px;\">Maitea<t t-out=\"object.firstname\"></t> ,<br><br> "
"Gizarte-kapitalera borondatezko ekarpena egiteko zure eskaera behar bezala "
"jaso dugula baieztatzen dugu.<b><t t-out=\"object.company_id.name\"></t></"
"b> , datu hauekin:<br><br><ul><li> Bazkidearen BEZa:<b><t t-"
"out=\"object.vat\"></t></b></li><li> Bazkidearen izena:<b><t t-"
"out=\"object.firstname\"></t><t t-out=\"object.lastname\"></t></b></li><li> "
"Kontua kargatzen amaitu da:<b><t t-out=\"object.iban[-4:]\"></t></b></"
"li><li> Harpidetza zenbatekoa: <b><t t-out=\"object.subscription_amount\"></"
"t>€</b></li></ul><br> Hurrengo egunetan bankuko kargua jasoko duzu kontu "
"honetan, mesedez egiaztatu emandako datu guztiak zuzenak direla eta "
"inbertitu nahi duzun dirua duzula, ordainagiriaren zirriborroan "
"gorabeherarik ekiditeko.<br><br> Ordainketaren baliozkotasuna egiaztatu "
"ondoren, egindako ekarpena berresten duen jakinarazpen berri bat jasoko "
"duzu.<br><br> Eskerrik asko zuen parte-hartzeagatik eta jakinarazten "
"dizuegu edozein zalantza edo argibide izanez gero,<t t-"
"if=\"object.company_id.website\"> kontsultatu gure webgunea:<a t-"
"if=\"object.company_id.website\" t-att-"
"href=\"object.company_id.website\"><t t-out=\"object.company_id.website\"></"
"t></a> edo</t> bidali mezu elektroniko bat helbide honetara<t t-"
"out=\"object.company_id.email\"></t> .<br><br> Zabaldu berria proiektua "
"familiari eta lagunei azalduz. Zenbat eta gehiago izan, orduan eta urrunago "
"iritsiko gara!<br> Mila esker eta energia ona!<br><br> Edozein zalantza "
"argitzeko harremanetan jarraitzen dugu.<br> Zurekin adeitasunez,<br></p></"
"div>\n"
"            "

#. module: energy_communities_cooperator
#: model:mail.template,body_html:energy_communities_cooperator.email_template_conditions_voluntary_share
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px; font-size: 13px;"
"\">\n"
"                    Hello <t t-out=\"object.name\"></t>,<br><br>\n"
"                    Recently we have allready charged your account the "
"amount corresponding to your voluntary contribution to the share capital of "
"<b><t t-out=\"object.company_id.comercial_name or "
"object.company_id.name\"></t></b>.<br><br>\n"
"                    We take this opportunity to <b>thank you</b>, once "
"again, for your involvement with the objective to promote actions and "
"projects that contribute to an energy and social transition.<br><br>\n"
"                    Please find in attachment your <t t-"
"out=\"object.company_id.comercial_name or object.company_id.name\"></t> "
"cooperator certificate.<br><br>\n"
"                    Get the word out by explaining the project to family "
"and friends. The more we are, the further we will go!<br><br>\n"
"                    We keep in touch for any questions.<br><br>\n"
"                    Yours faithfully,<br>\n"
"                </p>\n"
"                </div>\n"
"            "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\"><p style=\"margin: 0px; padding: "
"0px; font-size: 13px;\">Kaixo<t t-out=\"object.name\"></t> ,<br><br> Duela "
"gutxi, zure kontuan kargatu dugu zure kapital sozialean egindako "
"borondatezko ekarpenari dagokion zenbatekoa.<b><t t-"
"out=\"object.company_id.comercial_name or object.company_id.name\"></t></"
"b> .<br><br> Aukera hau baliatzen dugu berriro ere <b>eskerrak emateko</b> "
"energia eta gizarte trantsizioan laguntzen duten ekintzak eta proiektuak "
"sustatzeko helburuarekin egindako inplikazioagatik.<br><br> Mesedez, "
"erantsian aurkituko duzu zure<t t-out=\"object.company_id.comercial_name or "
"object.company_id.name\"></t> lankidetza-ziurtagiria.<br><br> Zabaldu "
"berria proiektua familiari eta lagunei azalduz. Zenbat eta gehiago izan, "
"orduan eta urrunago iritsiko gara!<br><br> Edozein zalantza argitzeko "
"harremanetan jarraitzen dugu.<br><br> Zurekin adeitasunez,<br></p></div>\n"
"            "

#. module: energy_communities_cooperator
#: model:mail.template,body_html:energy_communities_cooperator.email_template_voluntary_share_interest_return
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px; font-size: 13px;"
"\">\n"
"                    Hello <t t-out=\"object.partner_id.firstname\"></t>,"
"<br><br>\n"
"                    We have generated the yearly interest return of your "
"voluntary shares contribution.<br>\n"
"                    <t t-if=\"object.partner_bank_id.acc_number\">\n"
"                    Soon you'll receive a transfer on your IBAN account "
"finished on: <t t-out=\"object.partner_bank_id.acc_number[-4:]\"></"
"t><br><br>.\n"
"                    </t>\n"
"                    <t t-else=\"\">\n"
"                    Soon you'll receive a transfer on your IBAN account."
"<br><br>\n"
"                    </t>\n"
"                    The summary of the transaction:<br>\n"
"                    <ul>\n"
"                        <t t-"
"if=\"object.voluntary_share_interest_return_id\">\n"
"                            <li><strong>Period:</strong> from <t t-"
"out=\"object.voluntary_share_interest_return_id.start_date_period.strftime('%d/"
"%m/%Y')\"></t> to <t t-"
"out=\"object.voluntary_share_interest_return_id.end_date_period.strftime('%d/"
"%m/%Y')\"></t></li>\n"
"                        </t>\n"
"                        <li><strong>Total contribution:</strong> <t t-"
"out=\"('%.2f'% object.voluntary_share_total_contribution).replace('.',',')"
"\"></t>€</li>\n"
"                        <li><strong>Total interest:</strong> <t t-"
"out=\"('%.2f'% object.amount_untaxed).replace('.',',')\"></t>€</li>\n"
"                        <li><strong>Taxes:</strong> <t t-out=\"('%.2f'% "
"object.amount_tax).replace('.',',')\"></t>€</li>\n"
"                        <li><strong>Total to receive:</strong> <t t-"
"out=\"('%.2f'% object.amount_total).replace('.',',')\"></t>€</li>\n"
"                    </ul>\n"
"                    <br>\n"
"                    Don't hesitate to contact us at <a t-"
"if=\"object.company_id.email\" t-att-href=\"object.company_id.email\"><t t-"
"out=\"object.company_id.email\"></t></a> for any question you might have "
"using the code: <t t-out=\"object.name\"></t><br>\n"
"                    Thanks for your contribution helping generate our green "
"energy.<br><br>\n"
"                    Yours faithfully,<br>\n"
"                    </p>\n"
"                </div>\n"
"            "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\"><p style=\"margin: 0px; padding: "
"0px; font-size: 13px;\">Kaixo<t t-out=\"object.partner_id.firstname\"></t> ,"
"<br><br> Zure borondatezko akzioen ekarpenaren urteko interes-itzulera "
"sortu dugu.<br><t t-if=\"object.partner_bank_id.acc_number\"> Laster zure "
"IBAN kontuan transferentzia bat jasoko duzu, honako datarekin amaituta:<t t-"
"out=\"object.partner_bank_id.acc_number[-4:]\"></t><br><br> .</t><t t-"
"else=\"\"> Laster transferentzia bat jasoko duzu zure IBAN kontuan."
"<br><br></t> Transakzioaren laburpena:<br><ul><t t-"
"if=\"object.voluntary_share_interest_return_id\"><li> <strong>Aldia:</"
"strong> -tik<t t-"
"out=\"object.voluntary_share_interest_return_id.start_date_period.strftime('%d/"
"%m/%Y')\"></t> ra<t t-"
"out=\"object.voluntary_share_interest_return_id.end_date_period.strftime('%d/"
"%m/%Y')\"></t></li></t><li> <strong>Ekarpen osoa:</strong><t t-"
"out=\"('%.2f'% object.voluntary_share_total_contribution).replace('.',',')"
"\"></t> €</li><li> <strong>Interes totala:</strong><t t-out=\"('%.2f'% "
"object.amount_untaxed).replace('.',',')\"></t> €</li><li> <strong>Zergak:</"
"strong><t t-out=\"('%.2f'% object.amount_tax).replace('.',',')\"></t> €</"
"li><li> <strong>Jasotzeko guztira:</strong><t t-out=\"('%.2f'% "
"object.amount_total).replace('.',',')\"></t> €</li></ul><br> Ez izan "
"zalantzarik gurekin harremanetan jartzeko helbidean.<a t-"
"if=\"object.company_id.email\" t-att-href=\"object.company_id.email\"><t t-"
"out=\"object.company_id.email\"></t></a> Kodea erabiliz edozein zalantza "
"izanez gero:<t t-out=\"object.name\"></t><br> Eskerrik asko gure energia "
"berdea sortzen laguntzeko zure ekarpenagatik.<br><br> Zurekin adeitasunez,"
"<br></p></div>\n"
"            "

#. module: energy_communities_cooperator
#. odoo-python
#: code:addons/energy_communities_cooperator/config.py:0
#, python-format
msgid ""
"<p id='sepa_text'>To become a member, you must first fill out this form, "
"where we ask you for your bank account details and authorization to issue a "
"direct debit to collect the initial contribution of <span "
"id='prodPrice'>%(product_price)s</span>%(currency_symbol)s</p>"
msgstr ""
"<p id='sepa_text'>Bazkide izateko, lehenik formulario hau bete behar duzu, "
"non zure banku-kontuaren datuak eta hasierako ekarpena ( <span "
"id='prodPrice'>%(product_price)s</span> %(currency_symbol)s) jasotzeko "
"zordunketa zuzena egiteko baimena eskatzen dizkizugun.</p>"

#. module: energy_communities_cooperator
#. odoo-python
#: code:addons/energy_communities_cooperator/config.py:0
#, python-format
msgid ""
"<p id='sepa_text'>To join, you must first fill out this form where we ask "
"for a bank account and authorization to issue a bank receipt to collect the "
"initial mandatory financial contribution of <span "
"id='prodPrice'>%(product_price)s</span>%(currency_symbol)s</p>"
msgstr ""
"<p id='sepa_text'>Bazkide egiteko, lehenik formulario hau bete behar duzu, "
"non banku-kontu bat eta hasierako derrigorrezko ekarpen ekonomikoa ( <span "
"id='prodPrice'>%(product_price)s</span> %(currency_symbol)s) jasotzeko "
"banku-agiria jaulkitzeko baimena eskatzen dizugun.</p>"

#. module: energy_communities_cooperator
#. odoo-python
#: code:addons/energy_communities_cooperator/config.py:0
#, python-format
msgid ""
"<p id='transfer_text'>To be a member you must fulfill this form and lateron "
"proceed to pay the initial share of <span id='prodPrice'>%(product_price)s</"
"span>%(currency_symbol)s by follow the steps you will receive by email.</p>"
msgstr ""
"<p id='transfer_text'>Bazkide izateko formulario hau bete behar duzu eta "
"gero <span id='prodPrice'>%(product_price)s</span> %(currency_symbol)s-ren "
"hasierako kuota ordaindu behar duzu posta elektronikoz jasoko dituzun "
"urratsak jarraituz.</p>"

#. module: energy_communities_cooperator
#. odoo-python
#: code:addons/energy_communities_cooperator/config.py:0
#, python-format
msgid ""
"<p id='transfer_text'>To become a member, you must first fill out this "
"questionnaire and then make the initial financial contribution of <span "
"id='prodPrice'>%(product_price)s</span>%(currency_symbol)s by following the "
"steps we will send you by email once we have received your request.</p>"
msgstr ""
"<p id='transfer_text'>Bazkide izateko, lehenik galdetegi hau bete behar "
"duzu eta ondoren hasierako ekarpen ekonomikoa egin behar duzu, <span "
"id='prodPrice'>%(product_price)s</span> %(currency_symbol)s-koa, zure "
"eskaera jaso ondoren posta elektronikoz bidaliko dizkizugun urratsak "
"jarraituz.</p>"

#. module: energy_communities_cooperator
#. odoo-python
#: code:addons/energy_communities_cooperator/config.py:0
#, python-format
msgid ""
"<p>Once you become a member, you will be able to use the services available "
"to the energy community and, at the same time, be part of a movement for "
"social transformation and a new energy model</p>"
msgstr ""
"<p>Behin kide egiten zarenean, energia komunitatearentzat eskuragarri "
"dauden zerbitzuak erabili ahal izango dituzu eta, aldi berean, gizarte "
"eraldaketarako eta energia eredu berri baten aldeko mugimendu baten parte "
"izan.</p>"

#. module: energy_communities_cooperator
#. odoo-python
#: code:addons/energy_communities_cooperator/config.py:0
#, python-format
msgid ""
"<p>Once your request has been received, you will receive a confirmation "
"email with instructions to follow.</p><p>Note: If you are not yet a member, "
"please complete the following forms: <a href='/subscription/member/"
"%(external_id)s'>INDIVIDUAL MEMBERSHIP REGISTRATION</a> and <a href='/"
"subscription/company_member/%(external_id)s'>LEGAL ENTITY MEMBERSHIP "
"REGISTRATION</a></p>"
msgstr ""
"<p>Zure eskaera jaso ondoren, jarraitu beharreko argibideekin baieztapen-"
"mezu elektroniko bat jasoko duzu.</p><p> Oharra: Oraindik bazkide ez "
"bazara, bete formulario hauek: <a href='/subscription/member/"
"%(external_id)s'>BANAKAKO BAZKIDE IZEN-EMATEA</a> eta <a href='/"
"subscription/company_member/%(external_id)s'>ERAKUNDE JURIDIKOAREN BAZKIDE "
"IZEN-EMATEA</a></p>"

