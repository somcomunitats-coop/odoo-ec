<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_form_crm_leads_validate_wizard" model="ir.ui.view">
            <field name="name">Assign CRM to coordinator company wizard</field>
            <field name="model">assign.crm.to.coordinator.company.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <field name="assigned_company_id"/>
                    <field name="summary"/>
                    <footer>
                        <button name="button_assign_to_coordinator_company" string="Assign" type="object" />
                        <button special="cancel" string="Cancel" class="btn-secondary" />
                    </footer>
                </form>
            </field>
        </record>
        <record id="action_assign_crm_to_coordinator_company" model="ir.actions.act_window">
            <field name="name">Assign to coordinator company</field>
            <field name="res_model">assign.crm.to.coordinator.company.wizard</field>
            <field name="target">new</field>
        </record>
        <record id="assign_crm_to_coordinator_company_wizard_button" model="ir.ui.view">
            <field name="name">assign.crm.to.coordinator.company.wizard.button</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_lead_view_form"/>
            <field name="arch" type="xml">
                <button name="iap_enrich" position="after">
                <button name="%(action_assign_crm_to_coordinator_company)d"
                        string="Assign to coordinator company"
                        type="action"
                        context="{'default_active_id': active_id}"
                />
                </button>
            </field>
        </record>
    </data>
</odoo>
