    </record>

    <record model="res.users.role" id="role_internal_user">
        <field name="priority">7</field>
        <field
          name="available_role_ids"
          eval="[
                   (5, 0, 0),
                   (4, ref('role_platform_admin')),
                   (4, ref('role_coord_admin')),
                   (4, ref('role_coord_worker')),
                   (4, ref('role_ce_admin')),
                   (4, ref('role_ce_manager')),
                   (4, ref('role_ce_member'))]"/>
