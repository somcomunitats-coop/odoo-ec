<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template
    id="community_data_form_fields_template"
    name="community_data_form_fields_template"
  >
      <div class="row">
        <div class="col-md-12">
          <div
          class="form-group field-cd_community_name"
          t-attf-class="form-group #{error and 'cd_community_name' in error and 'has-error' or ''}"
          name="cd_community_name_container"
        >
            <label for="cd_community_name"><t t-esc="cd_community_name_label" /></label>
            <input
            class="form-control form-control-sm"
            id="cd_community_name"
            type="text"
            name="cd_community_name"
            t-attf-value="#{cd_community_name or ''}"
          />
          </div>
        </div>
        <div class="col-md-12">
          <div
          class="form-group field-cd_address"
          t-attf-class="form-group #{error and 'cd_address' in error and 'has-error' or ''}"
          name="cd_address_container"
        >
            <label for="cd_address"><t t-esc="cd_address_label" /></label>
            <input
            class="form-control form-control-sm"
            id="cd_address"
            type="text"
            name="cd_address"
            t-attf-value="#{cd_address or ''}"
          />
          </div>
        </div>
        <div class="col-md-12">
          <div
          class="form-group field-cd_zip"
          t-attf-class="form-group #{error and 'cd_zip' in error and 'has-error' or ''}"
          name="cd_zip_container"
        >
            <label for="cd_zip"><t t-esc="cd_zip_label" /></label>
            <input
            class="form-control form-control-sm"
            id="cd_zip"
            type="text"
            name="cd_zip"
            t-attf-value="#{cd_zip or ''}"
          />
          </div>
        </div>
        <div class="col-md-12">
          <div
          class="form-group field-cd_state_id"
          t-attf-class="form-group #{error and 'cd_state_id' in error and 'has-error' or ''}"
          name="cd_state_id_container"
        >
            <label for="cd_state_id"><t t-esc="cd_state_id_label" /></label>
            <select
            class="form-control form-control-sm"
            id="cd_state_id"
            name="cd_state_id"
            t-attf-value="#{cd_state_id or ''}"
          >
              <option value="">Please choose an option</option>
              <t t-foreach="states or []" t-as="state">
                <option
                t-att-value="state.id"
                t-att-selected="state.id == int(cd_state_id)"
              >
                  <t t-esc="state.name" />
                </option>
              </t>
            </select>
          </div>
        </div>
        <div class="col-md-12">
          <div
          class="form-group field-cd_contact_email"
          t-attf-class="form-group #{error and 'cd_contact_email' in error and 'has-error' or ''}"
          name="cd_contact_email_conatiner"
        >
            <label for="cd_contact_email"><t t-esc="cd_contact_email_label" /></label>
            <input
            class="form-control form-control-sm"
            autocapitalize="off"
            type="email"
            name="cd_contact_email"
            id="cd_contact_email"
            t-attf-value="#{cd_contact_email or ''}"
          />
          </div>
        </div>
        <div class="col-md-12">
          <div
          t-attf-class="form-group #{error and 'cd_primary_image_file' in error and 'has-error' or ''}"
          name="cd_primary_image_file_container"
        >
            <label for="cd_primary_image_file"><t
              t-esc="cd_primary_image_file_label"
            /></label>
            <input
            type="file"
            class="form-control form-control-sm"
            name="cd_primary_image_file"
            t-attf-value="#{cd_primary_image_file or ''}"
          />
          </div>
        </div>
        <div class="col-md-12">
          <div
          t-attf-class="form-group #{error and 'cd_secondary_image_file' in error and 'has-error' or ''}"
          name="cd_secondary_image_file_container"
        >
            <label for="cd_secondary_image_file"><t
              t-esc="cd_secondary_image_file_label"
            /></label>
            <input
            type="file"
            class="form-control form-control-sm"
            name="cd_secondary_image_file"
            t-attf-value="#{cd_secondary_image_file or ''}"
          />
          </div>
        </div>
      </div>
    </template>

    <template
    id="community_data_close_message_template"
    name="community_data_close_message_template"
  >
        <button type="button" class="close" data-dismiss="alert">
          &amp;times;
        </button>
    </template>

    <template
    id="community_data_error_message_template"
    name="community_data_error_message_template"
  >
      <t t-foreach="error_msgs or []" t-as="error_msg">
        <div class="alert alert-danger">
          <t t-raw="error_msg" />
        </div>
      </t>
    </template>

    <template
    id="community_data_form_successful_msg"
    name="community_data_form_successful_msg"
  >
      <div class="alert alert-success">
        <p>
          Your data has been successfully registered.
        </p>
        <a type="button" t-attf-href="#{page_url}" class="btn btn-light">
          Submit more data
        </a>
      </div>
    </template>

    <template
    id="community_data_form_csrf_template"
    name="community_data_form_csrf_template"
  >
      <div name="csrf_token_container">
        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" />
      </div>
    </template>

    <template id="community_data_form" name="community_data_form">
      <form
      t-attf-action="#{form_submit_url}"
      method="post"
      class="form-horizontal mt32 oe_subscription_request_form"
      enctype="multipart/form-data"
    >
        <t t-call="energy_communities.community_data_form_csrf_template" />
        <t t-call="energy_communities.community_data_form_fields_template" />
        <div class="text-center">
          <button class="btn btn-primary mt-3 mb-3 text-center">Send</button>
        </div>
      </form>
    </template>

    <template id="community_data_page" name="Communnity data">
      <t t-call="website.layout">
        <div id="wrap" class="o_portal_wrap">
          <div class="container oe_cooperator">
            <div class="row justify-content-center">
              <div class="col-xs-12 col-sm-10  col-md-8 col-lg-6">
                <h1 class="mt-4 text-center">Community data</h1>
                <t t-call="energy_communities.community_data_error_message_template" />
                <t
                t-if="display_success"
                t-call="energy_communities.community_data_form_successful_msg"
              />
                <t
                t-if="display_form"
                t-call="energy_communities.community_data_form"
              />
              </div>
            </div>
          </div>
        </div>
      </t>
    </template>
</odoo>
