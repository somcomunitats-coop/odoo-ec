<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="community_data_form_field_text" name="community_data_form_field_text">
      <div
      t-attf-name="#{key}_container"
      t-attf-class="form-group #{error and key in error and 'has-error' or ''} field-#{key}"
    >
        <label t-att="{'for': key}"><t t-esc="label" /></label>
        <input
        class="form-control form-control-sm"
        t-attf-id="#{key}"
        type="text"
        t-attf-name="#{key}"
        t-attf-value="#{value or ''}"
      />
      </div>
    </template>
    <template
    id="community_data_form_field_email"
    name="community_data_form_field_email"
  >
      <div
      t-attf-name="#{key}_container"
      t-attf-class="form-group #{error and key in error and 'has-error' or ''} field-#{key}"
    >
        <label t-att="{'for': key}"><t t-esc="label" /></label>
        <input
        class="form-control form-control-sm"
        t-attf-id="#{key}"
        autocapitalize="off"
        type="email"
        t-attf-name="#{key}"
        t-attf-value="#{value or ''}"
      />
      </div>
    </template>
    <template
    id="community_data_form_field_textarea"
    name="community_data_form_field_textarea"
  >
      <div
      t-attf-name="#{key}_container"
      t-attf-class="form-group #{error and key in error and 'has-error' or ''} field-#{key}"
    >
        <label t-att="{'for': key}"><t t-esc="label" /></label>
        <textarea
        class="form-control form-control-sm"
        t-attf-id="#{key}"
        t-attf-name="#{key}"
        t-attf-rows="#{rows}"
      ><t t-esc="value or ''" /></textarea>
      </div>
    </template>
    <template
    id="community_data_form_fields_template"
    name="community_data_form_fields_template"
  >
      <div class="row">
        <div class="col-md-12">
          <t t-call="energy_communities.community_data_form_field_text">
            <t t-set="value" t-value="ce_name" />
            <t t-set="key" t-value="ce_name_key" />
            <t t-set="label" t-value="ce_name_label" />
          </t>
        </div>
        <div class="col-md-12">
          <t t-call="energy_communities.community_data_form_field_text">
            <t t-set="value" t-value="ce_fiscal_name" />
            <t t-set="key" t-value="ce_fiscal_name_key" />
            <t t-set="label" t-value="ce_fiscal_name_label" />
          </t>
        </div>
        <div class="col-md-12">
          <t t-call="energy_communities.community_data_form_field_textarea">
            <t t-set="value" t-value="ce_description" />
            <t t-set="key" t-value="ce_description_key" />
            <t t-set="label" t-value="ce_description_label" />
            <t t-set="rows" t-value="5" />
          </t>
        </div>
        <div class="col-md-12">
          <t t-call="energy_communities.community_data_form_field_textarea">
            <t t-set="value" t-value="ce_long_description" />
            <t t-set="key" t-value="ce_long_description_key" />
            <t t-set="label" t-value="ce_long_description_label" />
            <t t-set="rows" t-value="5" />
          </t>
        </div>
        <div class="col-md-6">
          <t t-call="energy_communities.community_data_form_field_text">
            <t t-set="value" t-value="ce_address" />
            <t t-set="key" t-value="ce_address_key" />
            <t t-set="label" t-value="ce_address_label" />
          </t>
        </div>
        <div class="col-md-6">
          <t t-call="energy_communities.community_data_form_field_text">
            <t t-set="value" t-value="ce_zip" />
            <t t-set="key" t-value="ce_zip_key" />
            <t t-set="label" t-value="ce_zip_label" />
          </t>
        </div>
        <div class="col-md-6">
          <t t-call="energy_communities.community_data_form_field_text">
            <t t-set="value" t-value="ce_city" />
            <t t-set="key" t-value="ce_city_key" />
            <t t-set="label" t-value="ce_city_label" />
          </t>
        </div>
        <div class="col-md-6">
          <div
          class="form-group field-cd_state_id"
          t-attf-class="form-group #{error and 'cd_state_id' in error and 'has-error' or ''}"
          name="cd_state_id_container"
        >
            <label for="cd_state_id"><t t-esc="cd_state_id_label" /></label>
            <select
            class="form-control form-control-sm"
            id="cd_state_id"
            name="cd_state_id"
            t-attf-value="#{cd_state_id or ''}"
          >
              <option value="">Please choose an option</option>
              <t t-foreach="states or []" t-as="state">
                <option
                t-att-value="state.id"
                t-att-selected="state.id == int(cd_state_id)"
              >
                  <t t-esc="state.name" />
                </option>
              </t>
            </select>
          </div>
        </div>
        <div class="col-md-12">
          <t t-call="energy_communities.community_data_form_field_email">
            <t t-set="value" t-value="email_from" />
            <t t-set="key" t-value="email_from_key" />
            <t t-set="label" t-value="email_from_label" />
          </t>
        </div>
        <div class="col-md-6">
          <div
          t-attf-class="form-group #{error and 'cd_primary_image_file' in error and 'has-error' or ''}"
          name="cd_primary_image_file_container"
        >
            <label for="cd_primary_image_file"><t
              t-esc="cd_primary_image_file_label"
            /></label>
            <label
            style="font-size:13px;font-family:'Roboto',sans-serif;font-weight:300;"
            t-if="cd_primary_image_file"
          >Upload a new one to change</label>
            <input
            type="file"
            accept="image/*"
            class="form-control form-control-sm primary-file"
            name="cd_primary_image_file"
          />
          </div>
        </div>
        <div class="col-md-6">
            <img
          t-if="cd_primary_image_file"
          t-attf-src="#{cd_primary_image_file}"
          width="100px"
        />
        </div>
        <div class="col-md-6">
          <div
          t-attf-class="form-group #{error and 'cd_secondary_image_file' in error and 'has-error' or ''}"
          name="cd_secondary_image_file_container"
        >
            <label for="cd_secondary_image_file"><t
              t-esc="cd_secondary_image_file_label"
            /></label>
            <label
            style="font-size:13px;font-family:'Roboto',sans-serif;font-weight:300;"
            t-if="cd_secondary_image_file"
          >Upload a new one to change</label>
            <input
            type="file"
            accept="image/*"
            class="form-control form-control-sm"
            name="cd_secondary_image_file"
          />
          </div>
        </div>
        <div class="col-md-6">
            <img
          t-if="cd_secondary_image_file"
          t-attf-src="#{cd_secondary_image_file}"
          width="100px"
        />
        </div>
      </div>
    </template>

    <template
    id="community_data_close_message_template"
    name="community_data_close_message_template"
  >
        <button type="button" class="close" data-dismiss="alert">
          &amp;times;
        </button>
    </template>

    <template
    id="community_data_error_message_template"
    name="community_data_error_message_template"
  >
      <t t-foreach="error_msgs or []" t-as="error_msg">
        <div class="alert alert-danger">
          <t t-raw="error_msg" />
        </div>
      </t>
    </template>

    <template
    id="community_data_form_successful_msg"
    name="community_data_form_successful_msg"
  >
      <div class="alert alert-success">
        <p>
          Your data has been successfully registered.
        </p>
        <a type="button" t-attf-href="#{page_url}" class="btn btn-light">
          Submit more data
        </a>
      </div>
    </template>

    <template
    id="community_data_form_csrf_template"
    name="community_data_form_csrf_template"
  >
      <div name="csrf_token_container">
        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" />
      </div>
    </template>

    <template id="community_data_form" name="community_data_form">
      <form
      t-attf-action="#{form_submit_url}"
      method="post"
      class="form-horizontal mt32 oe_subscription_request_form"
      enctype="multipart/form-data"
    >
        <t t-call="energy_communities.community_data_form_csrf_template" />
        <t t-call="energy_communities.community_data_form_fields_template" />
        <div class="text-center">
          <button class="btn btn-primary mt-3 mb-3 text-center">Send</button>
        </div>
      </form>
    </template>

    <template id="community_data_page" name="Communnity data">
      <t t-call="website.layout">
        <div id="wrap" class="o_portal_wrap">
          <div class="container oe_cooperator">
            <div class="row justify-content-center">
              <div class="col-xs-12 col-sm-10  col-md-8 col-lg-6">
                <h1 class="mt-4 text-center">Community data</h1>
                <t t-call="energy_communities.community_data_error_message_template" />
                <t
                t-if="display_success"
                t-call="energy_communities.community_data_form_successful_msg"
              />
                <t
                t-if="display_form"
                t-call="energy_communities.community_data_form"
              />
              </div>
            </div>
          </div>
        </div>
      </t>
    </template>
</odoo>
