          <!--        </option>-->
          <!--      </t>-->
          <!--    </option>-->
          <!--  </select>-->
          <!--</div>-->
        </div>
        <div class="col-md-6">
          <div
          class="form-group field-phone"
          t-attf-class="form-group #{error and 'phone' in error and 'has-error' or ''}"
          name="phone_container"
        >
            <label for="phone">Phone</label>
            <input
            class="form-control form-control-sm"
            id="phone"
            type="tel"
            name="phone"
            required="True"
