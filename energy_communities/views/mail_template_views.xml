<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="email_template_form">
      <field name="name">mail.template.form (in energy_communities)</field>
      <field name="model">mail.template</field>
      <field name="inherit_id" ref="mail_template_multi_company.mail_template_form_view" />
      <field name="arch" type="xml">
        <button name="%(mail.mail_template_reset_action)d" position="attributes">
          <attribute name="groups">energy_communities.role_platform_admin</attribute>
        </button>
        <field name="company_id" position="before">
          <field name="user_current_role" invisible="1"/>
        </field>
        <field name="company_id" position="attributes">
          <attribute name="attrs">{'readonly': [('user_current_role','!=','role_platform_admin')]}</attribute>
        </field>
      </field>
    </record>
    <record id="ce_mail_template_search_view" model="ir.ui.view">
        <field name="name">mail.template.search (in energy_communities)</field>
        <field name="model">mail.template</field>
        <field name="inherit_id" ref="mail_template_multi_company.mail_template_search_view" />
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='base_templates']" position="before">
              <group expand="0" string="Ce Templates">
                <filter name="global_templates" string="Global Templates" domain="[('company_id', '=', False)]" />
                <filter name="ce_custom_templates" string="Ce Custom Templates" domain="[('company_id', '!=',  False)]"/>
              </group>
            </xpath>
            <xpath expr="//filter[@name='base_templates']" position="replace">
              <filter name="base_templates" string="Base Templates" domain="[('template_category', '=', 'base_template')]" groups="energy_communities.role_platform_admin_res_groups"/>
            </xpath>
            <xpath expr="//filter[@name='custom_templates']" position="replace">
              <filter name="custom_templates" string="Custom Templates" domain="[('template_category', '=', 'custom_template')]" groups="energy_communities.role_platform_admin_res_groups"/>
            </xpath>
        </field>
    </record>
    <record model="ir.actions.act_window" id="mail.action_email_template_tree_all">
      <field name="name">Email Templates</field>
      <field name="res_model">mail.template</field>
      <field name="view_mode">list,form</field>
      <field name="view_id" ref="mail_template_multi_company.mail_template_tree_view" />
      <field name="search_view_id" ref="energy_communities.ce_mail_template_search_view"/>
      <field name="context">{'search_default_base_templates': 0, 'group_by': 'model_id'}</field>
    </record>
  </data>
</odoo>
